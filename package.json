{
	"name": "claude-code-data",
	"version": "2.0.0",
	"description": "Parser for Claude Code's local session data (~/.claude/).",
	"type": "module",
	"license": "MIT",
	"author": "guiziweb",
	"homepage": "https://github.com/Guiziweb/claude-code-data",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Guiziweb/claude-code-data.git"
	},
	"bugs": {
		"url": "https://github.com/Guiziweb/claude-code-data/issues"
	},
	"keywords": [
		"claude-code",
		"jsonl",
		"sessions",
		"parser"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"default": "./dist/index.mjs"
		}
	},
	"main": "./dist/index.mjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"files": [
		"dist"
	],
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"build": "tsdown",
		"prepack": "bun run build",
		"test": "bun test",
		"typecheck": "tsc --noEmit",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"check": "biome check .",
		"ci": "bun run check && bun run typecheck && bun test --coverage && bunx typedoc --entryPoints src/index.ts --out docs --treatWarningsAsErrors"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.14",
		"@types/bun": "^1.3.13",
		"tsdown": "^0.21.10",
		"typedoc": "^0.28.19",
		"typescript": "^6.0.3"
	},
	"dependencies": {
		"valibot": "^1.3.1"
	}
}
