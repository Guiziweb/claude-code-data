{
	"name": "claude-data-api",
	"version": "0.0.0",
	"description": "GraphQL gateway for Claude Code's local data.",
	"type": "module",
	"license": "MIT",
	"author": "guiziweb",
	"homepage": "https://github.com/guiziweb/claude-data-api",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/guiziweb/claude-data-api.git"
	},
	"bugs": {
		"url": "https://github.com/guiziweb/claude-data-api/issues"
	},
	"keywords": [
		"claude-code",
		"graphql",
		"api",
		"jsonl",
		"sessions"
	],
	"engines": {
		"bun": ">=1.3.0"
	},
	"scripts": {
		"dev": "bun --watch src/index.ts",
		"start": "bun src/index.ts",
		"test": "bun test",
		"typecheck": "tsc --noEmit",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"check": "biome check .",
		"schema:export": "bun scripts/export-schema.ts",
		"probe:local": "bun scripts/probe-local.ts",
		"prepare": "git config core.hooksPath .githooks"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.14",
		"@types/bun": "^1.3.13",
		"typescript": "^6.0.3"
	},
	"dependencies": {
		"@pothos/core": "^4.12.0",
		"chokidar": "^5.0.0",
		"graphql": "^16.13.2",
		"graphql-scalars": "^1.25.0",
		"graphql-yoga": "^5.21.0",
		"valibot": "^1.3.1"
	}
}
